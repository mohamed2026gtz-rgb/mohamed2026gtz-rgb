# Copy to .env before local dev or EAS cloud build (do not commit .env).

# Production SLNECB portal (Ubuntu server)
EXPO_PUBLIC_API_BASE_URL=https://portal.slnecb.org

# Local LAN dev (uncomment for testing on office Wi-Fi)
# EXPO_PUBLIC_API_BASE_URL=http://192.168.x.x:5103

# EXPO_PUBLIC_SSL_PIN_SHA256=
# EXPO_PUBLIC_PREFER_HTTPS=true

# Database is on the API server (DB_NAME=Sneo_final)

# APK build:
# npm install && npx eas login && npm run build:android