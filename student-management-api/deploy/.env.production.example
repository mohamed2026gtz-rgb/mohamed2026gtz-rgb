# Production on Render — set these in Render Dashboard (API service env vars)
NODE_ENV=production
APP_VERSION=1.0.0

# External MySQL (Aiven / Railway — Render does not host MySQL)
DB_HOST=your-mysql-host.aivencloud.com
DB_PORT=3306
DB_NAME=Sneo_final
DB_USER=sneo_app
DB_PASSWORD=CHANGE_ME

JWT_SECRET=CHANGE_ME_AT_LEAST_32_CHARACTERS_LONG
JWT_ISSUER=StudentManagementAPI
JWT_AUDIENCE=StudentManagementApp

API_PUBLIC_URL=https://portal.slnecb.org
CORS_ORIGIN=https://admin.slnecb.org,https://portal.slnecb.org

IMAGE_SHARE_HOST=
IMAGE_SHARE_ROOT=