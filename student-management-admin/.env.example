# Leave empty for smart LAN detection (uses same PC IP as the browser + port 5103).
# Only set this if the API runs on a different machine than the admin site.
VITE_API_BASE_URL=

# Optional comma-separated fallbacks, e.g. http://192.168.20.153:5103,http://192.168.20.12:5103
VITE_LAN_API_URLS=

# Dev-only: proxy target when using npm run dev on localhost
VITE_API_PROXY=http://localhost:5103

# Database is configured on the API server (student-management-api/.env → DB_NAME=Sneo_final)